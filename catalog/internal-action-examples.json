{
  "description": "Real-world examples of action types (from captured workflows). Useful when the main catalog does not include a type (notably the truly internal primitives that are bundled in the SPA, not served by the assets endpoint).",
  "examples": [
    {
      "type": "add_contact_tag",
      "name": "Add Tag",
      "attributes": {
