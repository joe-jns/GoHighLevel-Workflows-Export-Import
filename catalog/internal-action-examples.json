          "type": "send_notification",
          "body": "{{contact.first_name}} est rentré dans le pipeline en tant que nouveau lead",
          "title": "{{contact.first_name}} est rentré dans le pipeline",
          "redirectPage": "opportunity",
          "userType": "all"
        }
      }
    },
    {
      "type": "internal_create_opportunity",
