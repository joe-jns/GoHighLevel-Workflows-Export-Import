        "__customInputFields__": [
          {
            "__customInputs__": {
              "value": "numerical"
            },
            "dataType": "SINGLE_OPTIONS",
            "filterField": "pipelineStageId",
            "value": "9868a080-9dee-4d0d-b734-8e765da94f82",
            "valueFieldType": "select"
          },
          {
            "__customInputs__": {},
            "dataType": "NUMERICAL",
            "filterField": "monetaryValue",
            "value": 2900,
            "valueFieldType": "numerical"
          }
